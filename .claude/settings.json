    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-hook-event.ts CwdChanged"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-hook-event.ts FileChanged"
          }
        ]
      }
    ],
    "MessageDisplay": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-hook-event.ts MessageDisplay"
          }
        ]
      }
    ]
  }
}