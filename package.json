{
  "name": "cc-hooks-ts",
  "version": "2.1.176",
  "description": "Write claude code hooks with type safety",
  "keywords": [
    "anthropic",
    "claude",
    "claude-code",
    "hooks",
    "type-safety",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/sushichan044/cc-hooks-ts/issues"
  },
  "license": "MIT",
  "author": {
    "name": "sushichan044",
    "url": "https://github.com/sushichan044"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushichan044/cc-hooks-ts.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
