    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-hook-event.ts SubagentStart"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-hook-event.ts SubagentStop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-hook-event.ts PreCompact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/log-hook-event.ts PostCompact"
          }
        ]
      }
