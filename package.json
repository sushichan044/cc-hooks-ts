  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.185",
    "get-stdin": "10.0.0",
    "valibot": "1.4.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.3",
    "@types/node": "25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260618.1",
    "@virtual-live-lab/tsconfig": "2.1.23",
    "pkg-pr-new": "0.0.75",
    "publint": "0.3.21",
    "release-it": "20.2.0",
    "release-it-pnpm": "4.6.6",
    "type-fest": "5.7.0",
    "typescript": "6.0.3",
    "unplugin-unused": "0.5.7",
    "vite-plus": "0.2.1"
